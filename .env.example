# ============================================================
# BeeShip Dispatch Center - Environment Configuration
# ============================================================
# Copy file này thành .env và điền giá trị thực vào

# --- Supabase ---
# Lấy từ: https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- Google Maps ---
# Lấy từ: https://console.cloud.google.com/apis/credentials
# Cần bật 2 API: "Maps JavaScript API" và "Places API" và "Directions API"
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
